# ============================================
# Backend Environment Variables
# Salin file ini menjadi .env dan isi dengan nilai sebenarnya
# ============================================

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Supabase Configuration
# Ambil dari Supabase Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Database
# (Optional - jika menggunakan raw database connection)
# DATABASE_URL=postgresql://...

# Security
# (Optional - untuk JWT secret jika menggunakan custom auth)
# JWT_SECRET=your_jwt_secret_key_here

# Email Configuration (Optional - untuk future email verification)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_email_password
# MAIL_FROM=noreply@yourapp.com
